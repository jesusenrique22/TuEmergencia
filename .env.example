# Flutter app environment (copy to .env)
# Web en tu Mac: localhost/127.0.0.1 está bien.
# Web desde OTRO dispositivo (misma Wi‑Fi): define DEV_HOST = IP del Mac.
API_BASE_URL=http://127.0.0.1:3000
SOCKET_URL=http://127.0.0.1:3001
# IP del Mac en Wi‑Fi (opcional: si abres http://IP:8088 en el móvil, la app deduce la IP sola)
# DEV_HOST=192.168.1.42
FLUTTER_WEB_PORT=8088
ENABLE_DEV_TOOLS=true

# ── Dev Tunnel (Cursor) — un solo túnel público en :8088 ──
# 1) Cursor → Puertos → solo 8088 → Público (3000/3001 quedan locales)
# 2) Copia el prefijo de la URL (ej. bbsl5rv7 de https://bbsl5rv7-8088….devtunnels.ms)
# 3) cd backend && pnpm run dev  +  cd realtime-gateway && pnpm run dev
# Ver docs/DEV_TUNNELS.md
TUNNEL_PREFIX=
# NO hace falta PUBLIC_API_URL / PUBLIC_SOCKET_URL (API y socket van por proxy en :8088)

# Solo migración legacy desde MongoDB (backend usa PostgreSQL)
# MONGODB_URI=mongodb://localhost:27017/smartmedic

# WebRTC TURN (opcional)
# WEBRTC_TURN_URL=turn:your-turn.example.com:3478
# WEBRTC_TURN_USERNAME=user
# WEBRTC_TURN_CREDENTIAL=secret

# Probar desde otro dispositivo:
# - Misma Wi‑Fi → docs/DEV_LAN.md (DEV_HOST + http://IP:8088)
# - Dev Tunnel → https://TU-PREFIJO-8088.use2.devtunnels.ms
# Comprobar: ./scripts/check-dev-ports.sh

# ── iOS / TestFlight (API en Render, no localhost) ──
# cp .env.ios.production.example .env.ios.production.local
# ./scripts/build-ios-testflight.sh
# Ver docs/TESTFLIGHT.md
