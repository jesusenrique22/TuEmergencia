# Copia a config/local-paths.env (opcional) para fijar rutas en esta Mac.
# Sin este archivo, ensure-local-paths usa los valores por defecto de abajo.

# SDK de Flutter (debe coincidir con dart.flutterSdkPath en .vscode/settings.json)
FLUTTER_SDK=/Users/smart/flutter

# Android SDK (local.properties)
ANDROID_SDK=/Users/smart/Library/Android/sdk

# Raíz del proyecto (normalmente no hace falta cambiarlo)
# PROJECT_ROOT=/Users/smart/Documents/Smart_Medic
