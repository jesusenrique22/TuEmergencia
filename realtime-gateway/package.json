{
  "name": "smart-medic-realtime-gateway",
  "version": "1.0.0",
  "description": "WebSocket gateway (Socket.IO) between Smart Medic clients and API",
  "packageManager": "pnpm@11.1.1",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "bash ../scripts/_bootstrap-dev-env.sh && ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:debug": "bash ../scripts/_bootstrap-dev-env.sh && ts-node-dev --inspect=9231 --transpile-only --no-notify src/index.ts",
    "build": "tsc"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.15",
    "@types/express": "^4.17.20",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.8.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}
