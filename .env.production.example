# Copia a .env antes de compilar para producción (NO commitear .env real).
# Sustituye las URLs por tus servicios en Render.
#
#   cp .env.production.example .env
#   # edita las URLs
#   ./scripts/build-web-production.sh
#
# O usa el script con variables:
#   API_BASE_URL=https://smart-medic-backend.onrender.com \
#   SOCKET_URL=https://smart-medic-gateway.onrender.com \
#   ./scripts/build-web-production.sh

API_BASE_URL=https://backend-pl89.onrender.com
SOCKET_URL=https://gateway-i9yu.onrender.com
ENABLE_DEV_TOOLS=false

# No uses en producción:
# TUNNEL_PREFIX=
# DEV_HOST=
# PUBLIC_API_URL=
# PUBLIC_SOCKET_URL=
